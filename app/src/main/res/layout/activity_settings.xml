<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Header: back button + title -->
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="&lt; Indietro"
            android:textSize="18sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Impostazioni"
            android:textSize="28sp"
            android:textStyle="bold"
            android:gravity="center" />

    </LinearLayout>

    <!-- Fields -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nome"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editFirstName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Mario"
                android:textSize="22sp"
                android:inputType="textPersonName|textCapWords"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cognome"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editLastName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Rossi"
                android:textSize="22sp"
                android:inputType="textPersonName|textCapWords"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Codice Fiscale"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editCF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="XXXXXXXXXXXXXXXX"
                android:textSize="22sp"
                android:inputType="textCapCharacters"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Telefono del Medico"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="+39..."
                android:textSize="22sp"
                android:inputType="phone"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Email del Medico"
                android:textSize="18sp"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/editEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="medico@esempio.it"
                android:textSize="22sp"
                android:inputType="textEmailAddress"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Metodo di Invio"
                android:textSize="18sp"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/radioSendMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="20dp">

                <RadioButton
                    android:id="@+id/radioWhatsApp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="WhatsApp"
                    android:textSize="22sp" />

                <RadioButton
                    android:id="@+id/radioSms"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="SMS"
                    android:textSize="22sp" />

                <RadioButton
                    android:id="@+id/radioEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Email"
                    android:textSize="22sp" />

            </RadioGroup>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Modello messaggio"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="{nome}  {cognome}  {COGNOME}  {cod_fisc}\n{lista(&quot;\n&quot;, {qta} x {farmaco})}"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:textColor="#666666"
                android:layout_marginBottom="6dp" />

            <EditText
                android:id="@+id/editTemplate"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:gravity="top"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:inputType="textMultiLine"
                android:layout_marginBottom="4dp" />

            <Button
                android:id="@+id/btnResetTemplate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ripristina default"
                android:textSize="14sp"
                android:layout_marginBottom="20dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Lista Farmaci"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Spunta quelli da selezionare di default"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:id="@+id/medicineListContainer"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp" />

            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:layout_marginBottom="20dp">

                <EditText
                    android:id="@+id/editNewMedicine"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Nuovo farmaco"
                    android:textSize="20sp"
                    android:inputType="textCapSentences" />

                <Button
                    android:id="@+id/btnAddMedicine"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aggiungi"
                    android:textSize="18sp" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Importa lista da testo"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Incolla una lista di farmaci (uno per riga). Usa [x] per selezionare di default."
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <EditText
                android:id="@+id/editImportText"
                android:layout_width="match_parent"
                android:layout_height="160dp"
                android:gravity="top"
                android:textSize="18sp"
                android:inputType="textMultiLine"
                android:hint="[x] 2 x Paracetamolo 1000 mg&#10;[ ] 1 x Ramipril 5 mg"
                android:layout_marginBottom="8dp" />

            <Button
                android:id="@+id/btnImport"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Importa"
                android:textSize="20sp"
                android:layout_marginBottom="24dp" />

            <!-- Nota privacy / GDPR -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🔒 Privacy: i dati inseriti (nome, cognome, codice fiscale) sono salvati solo su questo dispositivo e non vengono trasmessi a nessun servizio esterno. Vengono inviati esclusivamente al destinatario da te configurato, solo quando premi INVIA."
                android:textSize="13sp"
                android:textColor="#666666"
                android:background="#F5F5F5"
                android:padding="12dp"
                android:lineSpacingMultiplier="1.3"
                android:layout_marginBottom="8dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Save button pinned at bottom -->
    <Button
        android:id="@+id/btnSave"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:text="SALVA"
        android:textSize="24sp"
        android:layout_margin="16dp" />

</LinearLayout>
